{
  "productName": "FATE",
  "version": "0.1.0",
  "identifier": "com.fate.core",
  "build": {
    "beforeDevCommand": "pnpm --filter frontend dev",
    "beforeBuildCommand": "pnpm --filter frontend build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "windows": [
      {
        "title": "FATE — Fully Automated Task Executive",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["all"],
    "icon": [],
    "category": "Utility"
  }
}
